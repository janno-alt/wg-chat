{
  "name": "wg-chat",
  "version": "0.1.0",
  "private": true,
  "description": "Mandantenfähiges, EU-konformes KI-Chatbot-Produkt für WordPress-Kundenseiten (kine.media)",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/widget",
    "packages/dashboard",
    "packages/mcp"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @wg-chat/backend",
    "build": "npm run build --workspace @wg-chat/shared && npm run build --workspace @wg-chat/backend && npm run build --workspace @wg-chat/widget",
    "migrate": "npm run migrate --workspace @wg-chat/backend",
    "seed": "npm run seed --workspace @wg-chat/backend",
    "widget:dev": "npm run dev --workspace @wg-chat/widget",
    "widget:build": "npm run build --workspace @wg-chat/widget",
    "dashboard:dev": "npm run dev --workspace @wg-chat/dashboard",
    "dashboard:build": "npm run build --workspace @wg-chat/dashboard",
    "typecheck": "tsc -b --pretty",
    "db:up": "docker compose up -d postgres",
    "stack:up": "docker compose up -d --build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
