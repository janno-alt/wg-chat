# ─────────────────────────────────────────────────────────────
#  wg-chat – Beispiel-Umgebungskonfiguration
#  Kopiere diese Datei nach .env und passe die Werte an.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8787
# Öffentliche Basis-URL des Backends (für CORS / Widget-Auslieferung)
PUBLIC_BASE_URL=http://localhost:8787

# PostgreSQL (mit pgvector). Im Docker-Stack zeigt der Backend-Container intern
# auf Host "postgres". Für Host-Runs (migrate/seed/dev) zählt DATABASE_URL unten.
# Host-Port des Postgres-Containers. Default 5432; bei Konflikt (z.B. laufende
# CRM-DB) auf z.B. 5433 setzen – DATABASE_URL dann ebenfalls anpassen.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://wgchat:wgchat@localhost:5432/wgchat

# ─── LLM-Provider (EU) ───
# Aktuell unterstützt: "mistral". (Vertex/Gemini-EU folgt über dieselbe Abstraktion.)
LLM_PROVIDER=mistral
MISTRAL_API_KEY=
# Modelle: günstig für RAG, größer nur bei Bedarf. IDs zur Laufzeit prüfbar.
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_BASE_URL=https://api.mistral.ai

# Embedding-Dimension (mistral-embed = 1024). Muss zum DB-Schema passen.
EMBEDDING_DIMENSIONS=1024

# ─── Kaskade / Kostensteuerung (Default-Schwellen, pro Tenant überschreibbar) ───
# Cosine-Ähnlichkeit (0..1): >= DIRECT => KB-Antwort direkt; >= RAG => RAG erlaubt; sonst Eskalation.
SIMILARITY_DIRECT_THRESHOLD=0.86
SIMILARITY_RAG_THRESHOLD=0.72
# Semantischer Cache-Treffer.
SIMILARITY_CACHE_THRESHOLD=0.95

# ─── KB-Ingestion / Admin-API ───
# Schlüssel für die gesicherten /api/admin-Endpunkte (KB pflegen, crawlen, Kosten).
# Leer = Admin-API deaktiviert. In Produktion einen starken Wert setzen.
ADMIN_API_KEY=
CRAWL_MAX_PAGES=20
CHUNK_MAX_CHARS=1000
CHUNK_OVERLAP=150

# pgvector HNSW Recall (höher = genauer/etwas langsamer)
HNSW_EF_SEARCH=100

# ─── Lead-Benachrichtigung per E-Mail (optional; ohne SMTP_HOST deaktiviert) ───
# Empfänger pro Tenant = tenant_settings.notify_email; Webhook = lead_webhook_url.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=wg-chat <no-reply@kine.media>

# Sicherheits-/Demo-Schalter: erlaubt jede Origin (nur Entwicklung!).
ALLOW_ALL_ORIGINS=true
